# Database (PostgreSQL with pgvector)
DATABASE_URL="postgresql://user:password@localhost:5432/emarket?schema=public"

# OpenAI (for product & knowledge embeddings)
OPENAI_API_KEY="sk-..."

# Store identifier
STORE_SLUG="electromarket"

# Admin auth
ADMIN_EMAIL="admin@electromarket.ua"
ADMIN_PASSWORD="change_me_before_production"
ADMIN_SECRET="generate_random_32_char_string"

# Region
REGION_BUNDLE="UA"

# Base URL for SEO (sitemap, OG, hreflang). Set on Vercel for production.
# NEXT_PUBLIC_BASE_URL=https://your-store-domain.com
